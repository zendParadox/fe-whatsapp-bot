// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enum untuk tipe transaksi
enum TransactionType {
  INCOME
  EXPENSE
}

// BARU: Enum untuk tipe langganan (Subscription)
enum PlanType {
  FREE
  PREMIUM
}

// BARU: Enum untuk metode pembayaran
enum PaymentMethodType {
  CASH
  SHOPEEPAY
  GOPAY
  BANK_TRANSFER
  DEBIT_CARD
  CREDIT_CARD
  E_WALLET // Untuk e-wallet lainnya
}

// 👤 Model untuk pengguna aplikasi
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  password     String
  whatsapp_jid String?  @unique
  avatar_url   String?  // URL foto profil di Supabase Storage
  currency     String   @default("IDR") // IDR or AUD
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt @default(now())

  transactions Transaction[]
  categories   Category[]
  budgets      Budget[]
  
  // Relasi ke token reset password
  resetTokens  ResetPasswordToken[]
  
  // Relasi ke hutang
  debts        Debt[]
  
  // Relasi ke LID mapping
  lidMappings  LidMapping[]
  
  // Relasi ke analisis bulanan AI
  monthlyAnalyses MonthlyAnalysis[]
  
  // Relasi ke feedback pengguna
  feedbacks    Feedback[] 

  // Subsription (Plan)
  plan_type            PlanType  @default(FREE)
  premium_valid_until  DateTime?

  subscriptions        Subscription[]

  // Kantong Keuangan (Wallet)
  wallets              Wallet[]

  // Pembayaran Manual
  manual_payments      ManualPayment[]
}

// 🔗 Model untuk mapping WhatsApp Linked ID ke nomor telepon
model LidMapping {
  id         String   @id @default(uuid())
  lid        String   @unique  // e.g., "162581826281610"
  phone      String             // e.g., "6282164351960"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  user_id    String?
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  
  @@index([lid])
  @@index([phone])
}

// 🔑 Model untuk token reset password
model ResetPasswordToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// 📒 Enum untuk tipe hutang
enum DebtType {
  HUTANG   // Saya berhutang (Payable)
  PIUTANG  // Orang lain berhutang (Receivable)
}

// 📒 Enum untuk status hutang
enum DebtStatus {
  UNPAID
  PAID
}

// 📒 Model untuk mencatat Hutang & Piutang
model Debt {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(12, 2)
  type        DebtType
  status      DebtStatus @default(UNPAID)
  person_name String   // Nama orang yang berhutang/di-hutangi
  description String?
  due_date    DateTime? 
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Kantong (Wallet) — opsional
  wallet_id   String?
  wallet      Wallet?  @relation(fields: [wallet_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([user_id, status])  // Filter by status (UNPAID/PAID)
  @@index([wallet_id])
}

// 🏷️ Model untuk kategori transaksi
model Category {
  id    String @id @default(uuid())
  name  String

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]

  @@unique([user_id, name])
}

// 🎯 Model untuk budget bulanan
model Budget {
  id        String  @id @default(uuid())
  amount    Decimal @db.Decimal(12, 2)
  month     Int // 1-12
  year      Int

  category_id String
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category_id, month, year])
}

// 🔄 Model Transaction yang sudah di-refactor
model Transaction {
  id          String   @id @default(uuid())
  type        TransactionType
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt @default(now())

  // DIUBAH: payment_method sekarang String untuk mendukung metode bayar dinamis
  payment_method String? // Opsional, mendukung input bebas seperti "transfer bca", "gopay", dll

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  category_id String?
  category    Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)

  // Kantong (Wallet) — opsional
  wallet_id String?
  wallet    Wallet? @relation(fields: [wallet_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([category_id])
  @@index([wallet_id])
  @@index([user_id, created_at])       // Dashboard date-range queries
  @@index([user_id, type, created_at]) // Trend data groupBy queries
}

// 🤖 Model untuk menyimpan analisis keuangan bulanan dari AI
model MonthlyAnalysis {
  id          String   @id @default(uuid())
  month       Int      // 1-12
  year        Int
  content     String   @db.Text  // Hasil analisis dari Gemini AI
  created_at  DateTime @default(now())
  
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, month, year])
  @@index([user_id])
}

// 📝 Enum untuk tipe feedback
enum FeedbackType {
  SUGGESTION
  BUG
  CRITICISM
  OTHER
}

// 📝 Model untuk feedback pengguna
model Feedback {
  id         String       @id @default(uuid())
  name       String?      // Opsional, user bisa kirim anonim
  email      String?      // Opsional
  message    String       @db.Text
  type       FeedbackType @default(OTHER)
  created_at DateTime     @default(now())

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
}

// 💎 Model untuk mencatat riwayat pembayaran langganan (Midtrans)
model Subscription {
  id               String   @id @default(uuid())
  user_id          String
  order_id         String   @unique // Berasal dari kita (contoh: SUB-12345)
  amount           Decimal  @db.Decimal(12, 2)
  status           String   // 'pending', 'settlement', 'expire', 'cancel'
  payment_type     String?  // qris, bank_transfer, gopay, dll
  midtrans_url     String?  // Link pembayaran (Snap URL)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// 💰 Model untuk kantong keuangan (Bank/E-Wallet)
model Wallet {
  id           String   @id @default(uuid())
  name         String   // "BCA", "Gopay", "Cash", dll
  icon         String?  // Emoji: "🏦", "💚", "💵"
  balance      Decimal  @db.Decimal(15, 2) @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user_id      String
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  transactions Transaction[]
  debts        Debt[]

  @@unique([user_id, name])
  @@index([user_id])
}

// 📢 Model untuk menyimpan riwayat broadcast
model BroadcastLog {
  id           String   @id @default(uuid())
  message      String   @db.Text
  filter       String
  total_sent   Int
  total_failed Int      @default(0)
  created_at   DateTime @default(now())
}

// 💸 Model untuk pembayaran manual (Transfer Bank/E-Wallet via Upload Struk)
model ManualPayment {
  id                String   @id @default(uuid())
  amount            Decimal  @db.Decimal(12, 2)
  receipt_image_url String   @db.Text
  months            Int      @default(1) // Durasi langganan dalam bulan
  status            String   // 'PENDING', 'APPROVED', 'REJECTED'
  notes             String?  // Catatan admin jika ditolak
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user_id           String
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}